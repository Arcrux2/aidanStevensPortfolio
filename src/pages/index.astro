---
const pageTitle = "Home";
---
<!doctype html>
<html lang="en">
  <body>
    <div class="container">
      <h1>Aidan Stevens<br /><span>Portfolio</span></h1>

      <h2>Projects</h2>

      <div class="project-grid">
        <a href="/pablosZombos" class="project-card zombo">
          <img src="/pablosZombos/menuPZ.png" alt="Pablos Zombos" />
          <div class="card-text">
            <h3>Pablo's Zombos</h3>
            <p>2D Zombie Shooter</p>
          </div>
        </a>

        <a href="/theGoldenGear" class="project-card gear">
          <img src="/goldenGear/menuGG.png" alt="The Golden Gear" />
          <div class="card-text">
            <h3>The Golden Gear</h3>
            <p>Steampunk Puzzle Platformer</p>
          </div>
        </a>

        <a href="/cyberRobbery" class="project-card cyber">
          <img src="/cyberRobbery/questionsCR.png" alt="Cyber Robbery" />
          <div class="card-text">
            <h3>Cyber Robbery</h3>
            <p>Cyber Security Lesson App</p>
          </div>
        </a>

        <a href="/flappyBird" class="project-card flappy">
          <img src="/flappyBird/flappyBirdGameplay.png" alt="Flappy Bird Remake" />
          <div class="card-text">
            <h3>Flappy Bird</h3>
            <p>Video Game Remake</p>
          </div>
        </a>
      </div>
    </div>

    <section class="contact-section">
      <h2>Contact Information</h2>

      <div class="contact-wrapper">
        <a href="mailto:stevensaidan46@gmail.com" class="contact-card">
          <div class="contact-info">
            <h3>Email</h3>
            <p>stevensaidan46@gmail.com</p>
          </div>
        </a>

        <a href="https://www.linkedin.com/in/aidan-stevens-731423364/" target="_blank" class="contact-card">
          <div class="contact-info">
            <h3>LinkedIn</h3>
            <p>Aidan Stevens</p>
          </div>
        </a>
      </div>
    </section>

    <footer>
      <p>&copy; Aidan Stevens | Built with Astro</p>
    </footer>

  </body>
</html>

  <style>
    body {
      background-color: #111827;
      color: white;
      font-family: sans-serif;
      margin: 0;
      padding: 40px 20px;
    }

    .container {
      max-width: 1000px;
      margin: 0 auto;
      text-align: center;
    }

    h1 { font-size: 3rem;
    margin-bottom: 10px;

    }
    h1 span {
    color: #ffffff;
    }

    h2 {
      font-size: 2rem;
      margin-bottom: 40px;
      border-bottom: 2px solid #374151;
      display: inline-block;
      padding-bottom: 10px;
    }


    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
      padding: 20px 0;
    }

    .project-card {
      background-color: #1f2937;
      border-radius: 15px;
      overflow: hidden;
      text-decoration: none;
      color: white;
      transition: all 0.3s ease;
      border: 4px solid #374151;
    }

    .project-card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      border-bottom: 1px solid #374151;
    }

    .card-text { padding: 20px; }
    .card-text h3 { margin: 0; font-size: 1.4rem; }
    .card-text p { margin: 5px 0 0; color: #9ca3af; font-size: 0.9rem; }

    .project-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
      border-color: #6366f1;
    }

    .zombo:hover {
    border-color: #22c55e;
    box-shadow: 0 0 15px rgba(34, 197, 94, 0.4);
    }

    .gear:hover {
    border-color: #D4AF37;
    box-shadow: 0 0 15px rgba(184, 115, 51, 0.6)
    }

    .cyber:hover {
    border-color: #2DD4BF;
    box-shadow: 0 0 15px rgba(14, 165, 233, 0.4);
    }

    .flappy:hover {
    border-color: #FACC15;
    box-shadow: 0 0 15px rgba(234, 88, 12, 0.6);
    }

    .contact-section {
        margin-top: 80px;
        padding-top: 40px;
        border-top: 1px solid #374151;
      }

      .contact-section p {
        color: #9ca3af;
        max-width: 600px;
        margin: 0 auto 30px;
        line-height: 1.6;
      }

      .contact-wrapper {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
      }

      .contact-card {
        background-color: #1f2937;
        border: 2px solid #374151;
        border-radius: 12px;
        padding: 20px 30px;
        text-decoration: none;
        color: white;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: all 0.3s ease;
        min-width: 250px;
      }

      .icon {
        font-size: 2rem;
      }

      .contact-info h3 {
        margin: 0;
        font-size: 1.1rem;
        color: #4f46e5;
      }

      .contact-info p {
        margin: 0;
        font-size: 0.9rem;
        color: white;
      }

      .contact-card:hover {
        transform: translateY(-5px);
        border-color: #4f46e5;
        box-shadow: 0 5px 15px rgba(79, 70, 229, 0.3);
      }

      footer {
        margin-top: 100px;
        padding-bottom: 40px;
        font-size: 0.8rem;
        color: #6b7280;
      }
  </style>



